---
import Layout from '../../layouts/Layout.astro';
import BuyCTA from '../../components/BuyCTA.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title="Blog — Databricks AI Practitioner Notes"
  description="Practitioner notes on Databricks AI — Mosaic AI, AgentBricks, MLflow, RAG, and the operational realities of production AI on the Lakehouse."
  keywords={['databricks blog', 'databricks practitioner blog', 'mosaic ai blog', 'databricks ai blog 2026']}
>
  <section class="max-w-3xl mx-auto px-5 sm:px-8 pt-16 sm:pt-24 pb-12">
    <p class="text-sm font-semibold text-[var(--color-accent)] uppercase tracking-wider">Blog</p>
    <h1 class="font-display text-4xl sm:text-5xl font-extrabold mt-3 tracking-tight">
      Field notes on Databricks AI.
    </h1>
    <p class="mt-6 text-lg text-[var(--color-ink-soft)] leading-relaxed">
      Shorter pieces between book updates — things I'm learning, patterns that surprised me,
      releases worth paying attention to.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-5 sm:px-8 pb-12">
    <ul class="divide-y divide-[var(--color-line)]">
      {posts.map((post) => (
        <li class="py-8">
          <a href={`/blog/${post.id}/`} class="group block">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <time class="text-xs text-[var(--color-muted)]">{fmt(post.data.pubDate)}</time>
              {post.data.tags.length > 0 && (
                <>
                  <span class="text-[var(--color-line)]">·</span>
                  <span class="text-xs text-[var(--color-accent-deep)]">
                    {post.data.tags.slice(0, 2).join(' · ')}
                  </span>
                </>
              )}
            </div>
            <h2 class="font-display text-2xl font-extrabold leading-snug group-hover:text-[var(--color-accent)] transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-3 text-[var(--color-ink-soft)] leading-relaxed">
              {post.data.description}
            </p>
            <p class="mt-3 text-sm font-medium text-[var(--color-accent)]">Read post →</p>
          </a>
        </li>
      ))}
    </ul>

    {posts.length === 0 && (
      <p class="text-center text-[var(--color-muted)] py-16">No posts yet. Check back soon.</p>
    )}
  </section>

  <BuyCTA />
</Layout>
