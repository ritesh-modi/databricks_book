---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page not found"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="max-w-3xl mx-auto px-5 sm:px-8 py-32 text-center">
    <p class="font-display text-7xl font-extrabold text-[var(--color-accent)]">404</p>
    <h1 class="font-display text-3xl sm:text-4xl font-extrabold mt-4 tracking-tight">This page is missing.</h1>
    <p class="mt-4 text-[var(--color-ink-soft)]">Try the homepage, the topics index, or the FAQ.</p>
    <div class="mt-8 flex justify-center flex-wrap gap-3">
      <a href="/" class="px-5 py-3 rounded-full bg-[var(--color-ink)] text-white font-semibold">Home</a>
      <a href="/topics/" class="px-5 py-3 rounded-full bg-white border border-[var(--color-line)] font-semibold">Topics</a>
      <a href="/faq/" class="px-5 py-3 rounded-full bg-white border border-[var(--color-line)] font-semibold">FAQ</a>
    </div>
  </section>
</Layout>
