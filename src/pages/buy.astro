---
import Layout from '../layouts/Layout.astro';
import { series, volumes } from '../data/book';

const ordered = [volumes.v3, volumes.v4];
---

<Layout
  title={`Buy — ${series.title}`}
  description={`Buy both volumes of ${series.title}. Volume 3 covers the Databricks platform foundation (Unity Catalog, Lakeflow, CI/CD). Volume 4 covers the AI build-out (Mosaic AI, Agent Bricks, MLflow 3, Lakebase). Available on Amazon as Kindle, Paperback, and Hardcover.`}
  keywords={[
    'buy databricks for practitioners',
    'databricks book amazon',
    'databricks for practitioners kindle',
    'databricks for practitioners paperback',
    'ritesh modi databricks book',
  ]}
>
  <section class="max-w-5xl mx-auto px-5 sm:px-8 pt-16 sm:pt-24 pb-8">
    <p class="text-sm font-semibold text-[var(--color-accent)] uppercase tracking-wider">Get the books</p>
    <h1 class="font-display text-4xl sm:text-5xl font-extrabold mt-3 tracking-tight">
      Two volumes. Read either standalone, or both for the complete picture.
    </h1>
    <p class="mt-5 text-lg text-[var(--color-ink-soft)] leading-relaxed max-w-3xl">
      Available on Amazon in Kindle, Paperback, and Hardcover. Kindle readers get free addendum
      updates as Databricks releases new platform features.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-5 sm:px-8 pb-20">
    <div class="grid md:grid-cols-2 gap-8">
      {ordered.map((v) => (
        <div id={v.key} class="bg-white rounded-3xl border border-[var(--color-line)] overflow-hidden flex flex-col scroll-mt-24">
          <div class="aspect-[2/3] bg-slate-100 overflow-hidden">
            <img src={v.coverImage} alt={`Cover of ${v.fullTitle}`} class="w-full h-full object-cover" />
          </div>
          <div class="p-6 sm:p-8 flex-1 flex flex-col">
            <p class="text-xs uppercase tracking-wider font-bold text-[var(--color-accent-deep)]">
              Volume {v.volume} · {v.chapterRange} · ~{v.pages} pages
            </p>
            <h2 class="font-display text-2xl font-extrabold mt-2 leading-tight">
              {v.fullTitle}
            </h2>
            <p class="mt-1 text-sm text-[var(--color-ink-soft)]">{v.seriesSubtitle}</p>
            <p class="mt-4 text-[var(--color-ink-soft)] leading-relaxed text-sm">{v.tagline}</p>

            <ul class="mt-5 space-y-1.5 text-sm text-[var(--color-ink-soft)]">
              {v.keyTopics.slice(0, 6).map((t) => (
                <li class="flex gap-2">
                  <span class="text-[var(--color-accent)] mt-1">•</span>
                  <span>{t}</span>
                </li>
              ))}
            </ul>

            <div class="mt-auto pt-6 flex flex-col gap-3">
              <a
                href={v.amazonUrl}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-[var(--color-accent)] text-white font-semibold hover:bg-[var(--color-accent-deep)] transition-colors"
              >
                Buy Volume {v.volume} on Amazon
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
              <p class="text-xs text-[var(--color-muted)] text-center">
                ${v.price.kindle.toFixed(2)} Kindle · ${v.price.paperback.toFixed(2)} Paperback · {v.format.join(' · ')}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 p-6 rounded-2xl bg-[var(--color-accent-soft)] border border-[var(--color-accent)]/20">
      <p class="font-bold text-[var(--color-ink)]">Which volume first?</p>
      <p class="mt-2 text-[var(--color-ink-soft)] text-sm leading-relaxed">
        If you're still figuring out Unity Catalog, Lakeflow, and how to ship production pipelines
        on Databricks — start with <strong>Volume 3</strong>. If your platform is already in place
        and you need RAG, agents, MLflow 3, and the AI stack — start with <strong>Volume 4</strong>.
        Each is self-contained; reading both gives you the end-to-end picture, from Auto Loader to
        Multi-Agent Supervisor.
      </p>
    </div>
  </section>
</Layout>
