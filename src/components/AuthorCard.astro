---
import { series } from '../data/book';
---

<section class="py-20 sm:py-24 bg-[var(--color-bg)]">
  <div class="max-w-6xl mx-auto px-5 sm:px-8">
    <div class="bg-white rounded-3xl border border-[var(--color-line)] p-8 sm:p-12 grid lg:grid-cols-[auto_1fr] gap-8 items-center">
      <div class="relative flex-shrink-0 mx-auto lg:mx-0">
        <div class="absolute -inset-3 bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-warm)] rounded-full opacity-25 blur-2xl"></div>
        <img
          src={series.author.image}
          alt={`${series.author.name}, ${series.author.title}`}
          width="160"
          height="160"
          loading="lazy"
          decoding="async"
          class="relative w-40 h-40 rounded-full object-cover ring-4 ring-white shadow-xl"
        />
      </div>

      <div>
        <p class="text-sm font-semibold text-[var(--color-accent)] uppercase tracking-wider">About the author</p>
        <h2 class="font-display text-2xl sm:text-3xl font-extrabold mt-2 tracking-tight">
          {series.author.name}
        </h2>
        <p class="mt-2 text-[var(--color-ink-soft)]">
          {series.author.title}
        </p>
        <p class="mt-5 text-[var(--color-ink-soft)] leading-relaxed">
          Head of AI at MarketOnce. Previously Principal Forward Deployed Engineer at Microsoft.
          Author of <strong>18 technology books</strong> on AI, cloud, and infrastructure, translated,
          adopted by universities, and distributed by Microsoft Azure to 100,000+ enterprise users.
          Speaker at Microsoft BUILD, .NET Conf, and Global Azure. Creator of Microsoft's open-source
          RAG Experiment Accelerator and LLMOps PromptFlow templates.
        </p>
        <p class="mt-3 text-[var(--color-ink-soft)] leading-relaxed">
          These two volumes are the synthesis of what works, written for engineers who are tired of
          reading marketing material.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href={series.author.url} target="_blank" rel="noopener" class="text-sm font-medium text-[var(--color-accent)] hover:underline">
            riteshmodi.com →
          </a>
          <a href="https://www.linkedin.com/in/riteshmodi/" target="_blank" rel="noopener" class="text-sm font-medium text-[var(--color-accent)] hover:underline">
            LinkedIn →
          </a>
          <a href="https://github.com/ritmodi" target="_blank" rel="noopener" class="text-sm font-medium text-[var(--color-accent)] hover:underline">
            GitHub →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
