---
import { series, volumes } from '../data/book';
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)] bg-white mt-24 pb-24 md:pb-12">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-12 grid gap-8 md:grid-cols-4">
    <div class="md:col-span-2">
      <p class="font-display text-lg font-bold">{series.title}</p>
      <p class="mt-1 text-xs uppercase tracking-wider text-[var(--color-muted)] font-semibold">
        Part of the {series.seriesName} series
      </p>
      <p class="mt-3 text-sm text-[var(--color-muted)] max-w-md leading-relaxed">
        {series.tagline}
      </p>
      <a
        href="/buy/"
        class="mt-4 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-accent)] text-white text-sm font-semibold hover:bg-[var(--color-accent-deep)]"
      >
        Get both volumes →
      </a>
    </div>
    <div>
      <p class="text-xs uppercase tracking-wider text-[var(--color-muted)] font-semibold">
        Volume {volumes.v3.volume}, Platform
      </p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/topics/unity-catalog/" class="hover:text-[var(--color-accent)]">Unity Catalog</a></li>
        <li><a href="/topics/lakeflow-sdp/" class="hover:text-[var(--color-accent)]">Lakeflow SDP</a></li>
        <li><a href="/topics/lakeflow-jobs/" class="hover:text-[var(--color-accent)]">Lakeflow Jobs</a></li>
        <li><a href="/topics/asset-bundles/" class="hover:text-[var(--color-accent)]">Asset Bundles (DAB)</a></li>
        <li><a href="/topics/databricks-cicd/" class="hover:text-[var(--color-accent)]">CI/CD on Databricks</a></li>
        <li><a href="/topics/lakehouse/" class="hover:text-[var(--color-accent)]">Lakehouse architecture</a></li>
      </ul>
      <p class="mt-4 text-xs uppercase tracking-wider text-[var(--color-muted)] font-semibold">
        Volume {volumes.v4.volume}, AI
      </p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/topics/rag-with-databricks/" class="hover:text-[var(--color-accent)]">RAG on Databricks</a></li>
        <li><a href="/topics/agentbricks/" class="hover:text-[var(--color-accent)]">Agent Bricks</a></li>
        <li><a href="/topics/multi-agent-systems/" class="hover:text-[var(--color-accent)]">Multi-Agent Systems</a></li>
        <li><a href="/topics/mlflow/" class="hover:text-[var(--color-accent)]">MLflow 3</a></li>
        <li><a href="/topics/vector-search/" class="hover:text-[var(--color-accent)]">Mosaic AI Vector Search</a></li>
        <li><a href="/topics/feature-stores/" class="hover:text-[var(--color-accent)]">Feature Store</a></li>
        <li><a href="/topics/mlops-on-databricks/" class="hover:text-[var(--color-accent)]">MLOps</a></li>
      </ul>
    </div>
    <div>
      <p class="text-xs uppercase tracking-wider text-[var(--color-muted)] font-semibold">The books</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/buy/" class="hover:text-[var(--color-accent)]">Buy</a></li>
        <li><a href="/preview/" class="hover:text-[var(--color-accent)]">Inside the books</a></li>
        <li><a href="/topics/" class="hover:text-[var(--color-accent)]">All topics</a></li>
        <li><a href="/about/" class="hover:text-[var(--color-accent)]">About the author</a></li>
        <li><a href="/faq/" class="hover:text-[var(--color-accent)]">FAQ</a></li>
        <li><a href="/reviews/" class="hover:text-[var(--color-accent)]">Reviews</a></li>
        <li><a href="/blog/" class="hover:text-[var(--color-accent)]">Blog</a></li>
        <li><a href="/rss.xml" class="hover:text-[var(--color-accent)]">RSS</a></li>
        <li><a href={series.author.url} target="_blank" rel="noopener" class="hover:text-[var(--color-accent)]">Author site →</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-[var(--color-line)]">
    <div class="max-w-6xl mx-auto px-5 sm:px-8 py-5 flex flex-col sm:flex-row gap-2 justify-between items-center text-xs text-[var(--color-muted)]">
      <p>© {year} {series.author.name}. All rights reserved.</p>
      <p>Independent of Databricks Inc. · Databricks® is a trademark of Databricks Inc.</p>
    </div>
  </div>
</footer>
