---
// Placeholder. Replace these with real endorsements from your reviewers.
const reviews = [
  {
    quote: "The books I wish I'd had when we started our Databricks migration. Volume 3 skips the marketing and goes straight to the operational reality of UC and Lakeflow.",
    name: 'Reviewer Placeholder',
    role: 'Staff Data Engineer at PLACEHOLDER',
  },
  {
    quote: "Ritesh writes the way senior engineers actually think, what's the failure mode, what's the cost, what breaks at scale. Volume 4 is the first book that treats Agent Bricks as a production tool.",
    name: 'Reviewer Placeholder',
    role: 'Principal Architect at PLACEHOLDER',
  },
  {
    quote: "Read both volumes back-to-back. By the end, the gap between 'we have a Databricks workspace' and 'we ship reliable systems on it' is closed.",
    name: 'Reviewer Placeholder',
    role: 'Director of AI Engineering at PLACEHOLDER',
  },
];
---

<section class="py-20 sm:py-24">
  <div class="max-w-6xl mx-auto px-5 sm:px-8">
    <div class="mb-12 max-w-2xl">
      <p class="text-sm font-semibold text-[var(--color-accent)] uppercase tracking-wider">What practitioners say</p>
      <h2 class="font-display text-3xl sm:text-4xl font-extrabold mt-2 tracking-tight">
        Endorsements
      </h2>
      <p class="mt-3 text-[var(--color-muted)] text-sm">
        Pre-launch reviews from senior engineers and architects who shipped Databricks AI systems
        before this book existed. Replace these placeholders with real quotes when you have them.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {reviews.map((r) => (
        <figure class="p-6 bg-white rounded-2xl border border-[var(--color-line)]">
          <svg class="w-8 h-8 text-[var(--color-accent)] opacity-20" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <blockquote class="mt-3 text-[var(--color-ink-soft)] leading-relaxed">
            "{r.quote}"
          </blockquote>
          <figcaption class="mt-5 pt-5 border-t border-[var(--color-line)]">
            <p class="font-semibold text-sm">{r.name}</p>
            <p class="text-xs text-[var(--color-muted)] mt-0.5">{r.role}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
