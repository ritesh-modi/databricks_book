---
import { volumes } from '../data/book';

const v3Topics = [
  { title: 'Unity Catalog', href: '/topics/unity-catalog/', desc: 'The three-level namespace, ABAC, governed tags, lineage, audit, and how UC becomes the platform contract.' },
  { title: 'Lakeflow SDP', href: '/topics/lakeflow-sdp/', desc: 'Spark Declarative Pipelines (formerly DLT), declarative bronze/silver/gold, data quality expectations, change data capture.' },
  { title: 'Lakeflow Jobs', href: '/topics/lakeflow-jobs/', desc: 'Orchestration on Databricks, task dependencies, event-driven triggers, retries, and the patterns that scale past 100 jobs.' },
  { title: 'Asset Bundles & CI/CD', href: '/topics/asset-bundles/', desc: 'Declarative Automation Bundles, CLI/SDK/Terraform, and GitHub Actions with OIDC, the production deployment story.' },
  { title: 'Lakehouse Architecture', href: '/topics/lakehouse/', desc: 'Delta Lake, Iceberg/UniForm, liquid clustering, predictive optimization, the storage substrate for everything above.' },
  { title: 'Performance Tuning', href: '/topics/performance-tuning/', desc: 'Photon, partitioning, clustering, caching, and the failure modes the Spark UI alone won\'t reveal.' },
];

const v4Topics = [
  { title: 'RAG on Databricks', href: '/topics/rag-with-databricks/', desc: 'Mosaic AI Vector Search, chunking strategy, retrieval evaluation, and the patterns that actually scale beyond a demo.' },
  { title: 'Agent Bricks', href: '/topics/agentbricks/', desc: 'Classification, information extraction, auto-tuning, and the cost-quality frontier. The declarative path to production agents.' },
  { title: 'Multi-Agent Systems', href: '/topics/multi-agent-systems/', desc: 'The Multi-Agent Supervisor, MCP, agent evaluation, tracing every hop, when single-agent is the right choice.' },
  { title: 'MLflow 3', href: '/topics/mlflow/', desc: 'Experiments, UC Model Registry, aliases, traces, evaluation. The operating system for ML and GenAI workflows.' },
  { title: 'Mosaic AI Vector Search', href: '/topics/vector-search/', desc: 'Delta-sync vs direct-access indexes, embedding choice, hybrid search, performance, and cost.' },
  { title: 'Feature Store on UC', href: '/topics/feature-stores/', desc: 'Point-in-time lookups, online serving from Lakebase, and avoiding training-serving skew.' },
  { title: 'MLOps & Lakehouse Monitoring', href: '/topics/mlops-on-databricks/', desc: 'Alias-driven promotion, champion/challenger, traffic splitting, and drift detection that actually fires when it should.' },
];
---

<section id="inside" class="py-20 sm:py-24 bg-white border-y border-[var(--color-line)]">
  <div class="max-w-6xl mx-auto px-5 sm:px-8">
    <div class="max-w-3xl mb-12">
      <p class="text-sm font-semibold text-[var(--color-accent)] uppercase tracking-wider">What's inside</p>
      <h2 class="font-display text-3xl sm:text-4xl font-extrabold mt-2 tracking-tight">
        Two volumes. The topics that actually decide whether you ship.
      </h2>
      <p class="mt-4 text-lg text-[var(--color-ink-soft)] leading-relaxed">
        Every chapter is written for engineers who need to ship, not "an introduction to," but
        "here is the architecture, here is the code, here is what breaks at scale, here is what it costs."
      </p>
    </div>

    <div class="mb-16">
      <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
        <div>
          <p class="text-xs uppercase tracking-wider font-bold text-[var(--color-accent-deep)]">
            Volume {volumes.v3.volume} · {volumes.v3.chapterRange} · ~{volumes.v3.pages} pages
          </p>
          <h3 class="font-display text-2xl font-extrabold mt-1">{volumes.v3.subtitle}</h3>
          <p class="mt-1 text-sm text-[var(--color-ink-soft)]">{volumes.v3.seriesSubtitle}</p>
        </div>
        <a href={`/buy/#${volumes.v3.key}`} class="text-sm font-semibold text-[var(--color-accent)]">Get Volume 3 →</a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {v3Topics.map((f) => (
          <a
            href={f.href}
            class="group block p-6 rounded-2xl border border-[var(--color-line)] bg-white hover:border-[var(--color-accent)] hover:shadow-lg transition-all"
          >
            <p class="font-display text-lg font-bold leading-snug group-hover:text-[var(--color-accent)] transition-colors">
              {f.title}
            </p>
            <p class="mt-3 text-sm text-[var(--color-ink-soft)] leading-relaxed">{f.desc}</p>
            <p class="mt-4 text-xs font-semibold text-[var(--color-accent)] uppercase tracking-wider">Read more →</p>
          </a>
        ))}
      </div>
    </div>

    <div>
      <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
        <div>
          <p class="text-xs uppercase tracking-wider font-bold text-[var(--color-accent-deep)]">
            Volume {volumes.v4.volume} · {volumes.v4.chapterRange} · ~{volumes.v4.pages} pages
          </p>
          <h3 class="font-display text-2xl font-extrabold mt-1">{volumes.v4.subtitle}</h3>
          <p class="mt-1 text-sm text-[var(--color-ink-soft)]">{volumes.v4.seriesSubtitle}</p>
        </div>
        <a href={`/buy/#${volumes.v4.key}`} class="text-sm font-semibold text-[var(--color-accent)]">Get Volume 4 →</a>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {v4Topics.map((f) => (
          <a
            href={f.href}
            class="group block p-6 rounded-2xl border border-[var(--color-line)] bg-white hover:border-[var(--color-accent)] hover:shadow-lg transition-all"
          >
            <p class="font-display text-lg font-bold leading-snug group-hover:text-[var(--color-accent)] transition-colors">
              {f.title}
            </p>
            <p class="mt-3 text-sm text-[var(--color-ink-soft)] leading-relaxed">{f.desc}</p>
            <p class="mt-4 text-xs font-semibold text-[var(--color-accent)] uppercase tracking-wider">Read more →</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
