---
interface Props {
  src: string;
  alt: string;
  caption: string;
  source?: string;
  /** Intrinsic image width in px, defaults to 800 (the book's standard figure width). */
  width?: number;
  /** Intrinsic image height in px, set explicitly to prevent CLS. */
  height?: number;
}
const { src, alt, caption, source, width = 800, height = 480 } = Astro.props;
---

<figure class="book-figure">
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
    decoding="async"
  />
  <figcaption>
    {source && <span class="figure-source">{source}</span>}
    {caption}
  </figcaption>
</figure>
