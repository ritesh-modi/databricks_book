---
import { series, volumes } from '../data/book';
const v3 = volumes.v3;
const v4 = volumes.v4;
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 -z-10"
    style="background:
      radial-gradient(ellipse 80% 60% at 50% -10%, rgba(255,54,33,0.12), transparent 60%),
      radial-gradient(ellipse 60% 50% at 90% 30%, rgba(31,111,235,0.10), transparent 60%);"
  ></div>

  <div class="max-w-6xl mx-auto px-5 sm:px-8 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="grid lg:grid-cols-[1.15fr_1fr] gap-12 lg:gap-16 items-center">
      <div>
        <div class="flex flex-wrap items-center gap-2 mb-6">
          <span class="inline-flex items-center gap-2 text-xs font-bold text-[var(--color-accent-deep)] bg-[var(--color-accent-soft)] px-3 py-1.5 rounded-full uppercase tracking-wider">
            Two volumes · 2026
          </span>
          <span class="text-xs text-[var(--color-muted)]">Part of the {series.seriesName} series</span>
        </div>

        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-tight">
          The practitioner's guide to <span class="text-[var(--color-accent)]">Databricks</span> — platform <em class="not-italic underline decoration-[var(--color-accent)] decoration-4 underline-offset-4">and</em> AI.
        </h1>

        <p class="mt-6 text-lg sm:text-xl text-[var(--color-ink-soft)] leading-relaxed max-w-2xl">
          Two books that together cover everything an engineer actually needs to ship on Databricks
          in 2026 — Unity Catalog, Lakeflow, ingestion, orchestration, CI/CD in
          <strong>Volume 3</strong>; Mosaic AI, Agent Bricks, MLflow 3, the Multi-Agent Supervisor,
          Lakebase in <strong>Volume 4</strong>. Read either standalone, or both for the complete picture.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/buy/"
            class="inline-flex items-center gap-2 px-7 py-4 rounded-full bg-[var(--color-accent)] text-white font-bold text-base hover:bg-[var(--color-accent-deep)] transition-colors shadow-lg shadow-red-500/20"
          >
            Get the books
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a
            href="/preview/"
            class="inline-flex items-center gap-2 px-7 py-4 rounded-full bg-white text-[var(--color-ink)] font-bold border border-[var(--color-line)] hover:border-[var(--color-ink)] transition-colors"
          >
            Read sample chapters
          </a>
        </div>

        <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-2xl">
          <div>
            <p class="font-display text-2xl font-extrabold text-[var(--color-ink)]">{v3.chapters + v4.chapters}</p>
            <p class="text-xs text-[var(--color-muted)] mt-1 uppercase tracking-wide">Chapters across two volumes</p>
          </div>
          <div>
            <p class="font-display text-2xl font-extrabold text-[var(--color-ink)]">~{v3.pages + v4.pages}</p>
            <p class="text-xs text-[var(--color-muted)] mt-1 uppercase tracking-wide">Pages of practitioner depth</p>
          </div>
          <div>
            <p class="font-display text-2xl font-extrabold text-[var(--color-ink)]">18×</p>
            <p class="text-xs text-[var(--color-muted)] mt-1 uppercase tracking-wide">Author of tech books</p>
          </div>
          <div>
            <p class="font-display text-2xl font-extrabold text-[var(--color-ink)]">2026</p>
            <p class="text-xs text-[var(--color-muted)] mt-1 uppercase tracking-wide">Latest features covered</p>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -inset-6 bg-gradient-to-br from-[var(--color-accent)] via-orange-400 to-[var(--color-warm)] rounded-3xl opacity-15 blur-3xl"></div>
        <div class="relative grid grid-cols-2 gap-4 sm:gap-6">
          {[v3, v4].map((vol, i) => (
            <a
              href={`/buy/#${vol.key}`}
              class={`relative aspect-[2/3] rounded-2xl shadow-2xl overflow-hidden bg-gradient-to-br from-slate-900 to-slate-700 border border-slate-800 ${i === 1 ? 'translate-y-6 sm:translate-y-8' : ''} hover:scale-[1.02] transition-transform`}
            >
              <img
                src={vol.coverImage}
                alt={`Cover of ${vol.fullTitle}`}
                class="w-full h-full object-cover"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
              <div class="absolute top-3 left-3 px-2.5 py-1 rounded-full bg-white/95 text-[var(--color-ink)] text-[10px] font-bold uppercase tracking-wider">
                Vol {vol.volume}
              </div>
            </a>
          ))}
        </div>

        <div class="absolute -bottom-4 -right-4 bg-white rounded-full px-4 py-2 shadow-lg border border-[var(--color-line)] flex items-center gap-2">
          <span class="text-xs font-semibold text-[var(--color-muted)]">From</span>
          <span class="font-display font-extrabold text-lg">${Math.min(v3.price.kindle, v4.price.kindle).toFixed(2)}</span>
        </div>
      </div>
    </div>
  </div>
</section>
