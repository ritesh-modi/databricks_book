---
import { series } from '../data/book';

const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return path === '/';
  return path.startsWith(href);
};

const links = [
  { href: '/topics/', label: 'Topics' },
  { href: '/preview/', label: 'Inside' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'Author' },
  { href: '/faq/', label: 'FAQ' },
];
---

<header class="sticky top-0 z-40 bg-white/90 backdrop-blur border-b border-[var(--color-line)]">
  <nav class="max-w-6xl mx-auto px-5 sm:px-8 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-display font-bold tracking-tight">
      <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[var(--color-ink)] text-[var(--color-accent)] text-sm font-black">D</span>
      <span class="hidden sm:inline text-base">{series.title}</span>
    </a>

    <button
      id="nav-toggle"
      class="md:hidden p-2 -mr-2 text-[var(--color-ink)]"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden md:flex items-center gap-7 text-sm font-medium">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class={`transition-colors hover:text-[var(--color-accent)] ${
              isActive(link.href) ? 'text-[var(--color-accent)]' : 'text-[var(--color-ink-soft)]'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/buy/"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-deep)] transition-colors font-semibold text-sm"
        >
          Get the books
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </li>
    </ul>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-line)] bg-white">
    <ul class="px-5 py-3 space-y-1">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class={`block py-2 text-base ${
              isActive(link.href) ? 'text-[var(--color-accent)] font-medium' : 'text-[var(--color-ink-soft)]'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/buy/"
          class="block mt-2 px-4 py-3 rounded-full bg-[var(--color-accent)] text-white text-center font-semibold"
        >
          Get the books →
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
